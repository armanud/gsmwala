# GSMarman Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret Key (Change this in production!)
JWT_SECRET=gsmarman-secret-key-2024-change-this-in-production

# MongoDB Configuration (Optional - for production use)
MONGODB_URI=mongodb://localhost:27017/gsmarman

# File Upload Configuration
MAX_FILE_SIZE=524288000
UPLOAD_PATH=./uploads

# Security Configuration
BCRYPT_ROUNDS=10
TOKEN_EXPIRY=24h

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
UPLOAD_RATE_LIMIT_WINDOW=60000
UPLOAD_RATE_LIMIT_MAX=10