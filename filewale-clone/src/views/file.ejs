<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= meta.originalName %> - Download</title>
  <style>
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, 'Helvetica Neue', Arial; line-height: 1.5; margin: 0; background: #0f172a; color: #e2e8f0; }
    .container { max-width: 720px; margin: 0 auto; padding: 32px 20px; }
    .card { background: #111827; border: 1px solid #1f2937; border-radius: 12px; padding: 24px; }
    .muted { color: #94a3b8; }
    button { background: #10b981; color: #052e1b; border: 0; padding: 10px 16px; border-radius: 8px; cursor: pointer; font-weight: 700; }
    a.button { text-decoration: none; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h2><%= meta.originalName %></h2>
      <p class="muted">Size: <%= (meta.sizeBytes/1024/1024).toFixed(2) %> MB • Expires: <%= new Date(meta.expiresAt).toLocaleString() %> • Downloads: <%= meta.downloads %></p>
      <a class="button" href="<%= downloadUrl %>"><button>Download</button></a>
    </div>
  </div>
</body>
</html>

