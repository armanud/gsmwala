<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Link expired</title>
  <style>
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, 'Helvetica Neue', Arial; line-height: 1.5; margin: 0; background: #0f172a; color: #e2e8f0; display: grid; place-items: center; min-height: 100vh; }
    .card { background: #111827; border: 1px solid #1f2937; border-radius: 12px; padding: 24px; max-width: 560px; }
    a { color: #60a5fa; }
  </style>
</head>
<body>
  <div class="card">
    <h2>Link expired</h2>
    <p>This file link has expired and is no longer available.</p>
    <p><a href="/">Upload a new file</a></p>
  </div>
</body>
</html>

